# .gitignore para projetos Python e Jupyter
# Mantém o diretório dataset versionado

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.env
.venv/
env/
venv/
ENV/

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
.coverage
.tox/
.nox/
.cache
.pytest_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Editor / OS files
.vscode/
*.swp
*~
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# pip
pip-wheel-metadata/

# Garantir que a pasta de dataset seja versionada
!dataset/
!dataset/*
